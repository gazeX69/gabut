{
  "name": "@vgz/scene-types",
  "version": "0.1.0",
  "description": "Canonical scene schema type definitions for VGZ engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./scene": {
      "import": "./dist/scene.js",
      "types": "./dist/scene.d.ts"
    },
    "./layer": {
      "import": "./dist/layer.js",
      "types": "./dist/layer.d.ts"
    },
    "./entity": {
      "import": "./dist/entity.js",
      "types": "./dist/entity.d.ts"
    },
    "./transform": {
      "import": "./dist/transform.js",
      "types": "./dist/transform.d.ts"
    },
    "./reference": {
      "import": "./dist/reference.js",
      "types": "./dist/reference.d.ts"
    },
    "./editorMeta": {
      "import": "./dist/editorMeta.js",
      "types": "./dist/editorMeta.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "vgz",
    "game-engine",
    "scene",
    "schema",
    "typescript",
    "serializable"
  ],
  "author": "VGZ Team",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.1.6"
  }
}
